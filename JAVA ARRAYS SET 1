class Solution {
    public String average(int arr[]) {
        // code here
        double avg;
        int size=arr.length;
        int sum =0;
        for(int i=0;i<size;i++){
           sum+=arr[i];
            
        }
        avg=(double)sum/size;
            String  ans = String.format("%.2f",avg);
      return ans;
    }
    
}
