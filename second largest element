class Solution {
    public int getSecondLargest(int[] arr) {
        // code here
      
        int n=arr.length;
        if(n<2){
            return -1;
        }
        int largest = arr[0];
        int secondlargest = -1;
        for(int i = 1;i<n;i++){
            if(arr[i]>largest){
                secondlargest=largest;
                largest=arr[i];
                
            }
             else if (arr[i] != largest && arr[i] > secondlargest) {
                secondlargest = arr[i];
            }
        }

        return secondlargest;
    }
}
