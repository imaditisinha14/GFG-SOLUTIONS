import java.util.Scanner;
public class squareprint {
    public static void main(String args[]){
        Scanner sc = new Scanner(System.in);

System.out.print("Enter no of row: ");
int n = sc.nextInt();
System.out.print("enter number of column: " );
int m = sc.nextInt();
for(int i = 1 ; i<=n;i++){
    for(int j =1;j<=m;j++){
        System.out.print(j+ " ");
        
    }
    System.out.println();
}
sc.close();
    }
}
