class Solution {
    boolean twoSum(int arr[], int target) {
        // code here
                for(int i=0;i<arr.length;i++){
            for(int j=i+1;j<arr.length;j++){
                int sum=arr[i]+arr[j];
                if(sum==target){
               return true;
                }
            }
                }
          return false;  
        
    }
}
