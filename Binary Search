class Solution {
    public boolean binarySearch(int[] arr, int target) {

        int lo = 0;
        int hi = arr.length - 1;

        while (lo <= hi) {
            int mid = lo + (hi - lo) / 2;

            if (arr[mid] == target) {
                return true;
            } 
            else if (target > arr[mid]) {
                lo = mid + 1;
            } 
            else {
                hi = mid - 1;
            }
        }

        return false;
    }
}
