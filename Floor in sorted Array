class Solution {
    static int findFloor(int[] arr, int x) {
        // code here
        int idx = -1;
        int lo=0;
        int hi=arr.length-1;
        while(lo<=hi){
            int mid = (lo+hi)/2;
            
            if(arr[mid]>x)
            hi=mid-1;
            
            else{ 
            idx=mid;
            lo=mid+1;
            }
            
        }
        return idx;
    }
}
